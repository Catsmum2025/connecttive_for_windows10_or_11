{
  "name": "connecttive-game-bar",
  "version": "1.0.0",
  "license": "MIT",
  "description": "联机棋类游戏桌面应用",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json",
    "build": "npm run build:renderer && npm run build:main",
    "pack": "npm run build && electron-builder --win portable",
    "pack:nsis": "npm run build && electron-builder --win nsis",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "build": {
    "appId": "com.connecttive.game-bar",
    "productName": "ConnectTive",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "target": "portable"
    },
    "portable": {
      "artifactName": "ConnectTive.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ConnectTive",
      "artifactName": "ConnectTive-Setup.${ext}"
    }
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
